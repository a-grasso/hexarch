{
  "name": "hexarch-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Standalone viewer for the hexarch hexagonal-architecture DSL",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:embed": "tsc -b && HEXARCH_EMBED=1 vite build --outDir dist-embed",
    "preview": "vite preview",
    "export": "node scripts/export.mjs",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.49.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vite-plugin-singlefile": "^2.1.0"
  }
}
